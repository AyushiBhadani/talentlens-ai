# TalentLens AI — Environment Configuration
# Copy this file to .env and fill in your values

# =============================================================
# REQUIRED: Get your free Gemini API key at https://aistudio.google.com
# =============================================================
GEMINI_API_KEY=your_gemini_api_key_here

# =============================================================
# Database (SQLite by default — no setup needed)
# =============================================================
DATABASE_URL=sqlite+aiosqlite:///./talentlens.db

# =============================================================
# ChromaDB vector store directory
# =============================================================
CHROMA_PERSIST_DIR=./chroma_db

# =============================================================
# File uploads
# =============================================================
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=10

# =============================================================
# CORS — add your frontend URL here
# =============================================================
ALLOWED_ORIGINS=["http://localhost:3000","https://talentlens-ai.vercel.app"]

# =============================================================
# Security — change this in production!
# =============================================================
SECRET_KEY=change-this-to-a-random-256-bit-key-in-production

# =============================================================
# Debug mode (set to False in production)
# =============================================================
DEBUG=False
